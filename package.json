{
  "name": "dinoz-sale",
  "version": "4.0.0",
  "description": "Node.js Express backend with SQLite for Dinoz Sale",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon --ignore database.sqlite --ignore public/ --ignore *.db src/server.js",
    "legacy": "node server.js",
    "postinstall": "npx prisma generate",
    "prisma:migrate": "npx prisma db push",
    "prisma:studio": "npx prisma studio"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.16.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "form-data": "^4.0.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "node-cron": "^4.2.1",
    "node-telegram-bot-api": "^0.67.0",
    "prisma": "^5.22.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
